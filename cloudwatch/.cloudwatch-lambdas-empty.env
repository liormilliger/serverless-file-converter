# ================================================================
#  cloudwatch-lambdas.env — deployment configuration
#  Used by deploy.sh. Keep this file out of version control.
#  Add it to .gitignore: echo "cloudwatch-lambdas.env" >> .gitignore
# ================================================================

# ── Stack ────────────────────────────────────────────────────
STACK_NAME=
REGION=
TEMPLATE_FILE=cloudwatch-lambdas.yaml

# ── Environment ──────────────────────────────────────────────
# Allowed values: development | staging | production
ENVIRONMENT=

# ── Alerting — SNS email subscriptions ──────────────────────
# Primary alert recipient (required)
ALERT_EMAIL=

# Additional recipients — optional, comma-separated
# These are added as extra SNS subscriptions after the stack deploys.
# Leave blank to skip.
#   EXTRA_ALERT_EMAILS=ops-team@yourcompany.com,oncall@yourcompany.com
EXTRA_ALERT_EMAILS=

# ── Lambda functions to monitor ──────────────────────────────
# Comma-separated, no spaces
LAMBDA_FUNCTION_NAMES=

# ── Step Function state machines to monitor ──────────────────
# Comma-separated ARNs, no spaces
STEP_FUNCTION_ARNS=

# ── Alarm thresholds ─────────────────────────────────────────
# Number of Lambda errors before alarm triggers
ERROR_ALARM_THRESHOLD=

# Number of Lambda throttles before alarm triggers
THROTTLE_ALARM_THRESHOLD=

# ── Log retention ────────────────────────────────────────────
# Days to retain CloudWatch logs
# Allowed values: 1 3 5 7 14 30 60 90 120 150 180 365
LOG_RETENTION_DAYS=